# 复制为 .env 并填写实际值；切勿将真实密钥提交到仓库
# 通用 Chat Completions 兼容端点（接口格式兼容，实际接入国产大模型服务）
LLM_API_URL=https://<国产云端大模型API>/v1/chat/completions
LLM_API_KEY=your-api-key-here
LLM_MODEL=DeepSeek-R1-Distill-Qwen-32B
# 本地/混合云私有化推理端点（可选，用于"数据不出校"）
# LLM_API_URL=http://<昇腾节点地址>:1234/v1/chat/completions
FLASK_ENV=production
SECRET_KEY=change-me-in-production
